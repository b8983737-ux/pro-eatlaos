# EATLAOS clean-URL routing for Cloudflare Pages.
# Serves the app for pretty paths on refresh (URL stays pretty, no redirect flicker).
# The app reads location.pathname (/r/<id>) and renders the right page.
/r/*            /app/index.html   200
/book           /app/index.html   200
/booking        /app/index.html   200
/my-booking     /app/index.html   200
/mybooking      /app/index.html   200
/check-booking  /app/index.html   200
/login          /app/index.html   200
/owner          /app/index.html   200
